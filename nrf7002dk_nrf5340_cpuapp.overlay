/ {
	chosen {
		nordic,pm-ext-flash = &mx25r64;
	};
};
&i2c1{
    status = "okay";
    clock-frequency =<I2C_BITRATE_STANDARD>;
    /* BMP280 */
    bmp280: bmp280@76 {
        compatible = "bosch,bme280";
        status = "okay";
        reg = <0x76>;
    };

    /* TMP117 */
    tmp117: tmp117@48 {
        compatible = "ti,tmp11x";
        status = "okay";
        reg = <0x48>;
    };
};
